# == REQUIRED — encrypted via SOPS ==

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Elixpo SSO (from accounts.elixpo.com developer dashboard)
ELIXPO_CLIENT_ID=
ELIXPO_CLIENT_SECRET=

# Session signing
JWT_SECRET=                    # 32-byte hex, `openssl rand -hex 32`

# AI Providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# External tools
TAVILY_API_KEY=                # web search
OPENWEATHER_API_KEY=           # weather

# Cloudinary (if using for image optimization)
CLOUDINARY_URL=

# == NEXT_PUBLIC (safe to expose) ==
NEXT_PUBLIC_APP_URL=https://chat.elixpo.com
NEXT_PUBLIC_ELIXPO_SSO_URL=https://accounts.elixpo.com
NEXT_PUBLIC_DEFAULT_MODEL=gpt-4o
